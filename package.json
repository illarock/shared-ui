{
  "name": "@shared/ui",
  "version": "0.1.0",
  "description": "Shared shadcn/ui component library for Next.js apps",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build:js": "tsup && node scripts/generate-exports.mjs",
    "build:css": "npx @tailwindcss/cli -i ./src/styles/build.css -o ./dist/styles.css --minify",
    "build": "npm run build:js && npm run build:css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illarock/shared-ui.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#lib/*": "./src/lib/*.ts",
    "#hooks/*": "./src/hooks/*.ts"
  },
  "exports": {
    "./styles.css": "./dist/styles.css",
    "./globals.css": "./dist/styles.css",
    "./styles/globals.css": "./dist/styles.css",
    "./preset.css": "./dist/preset.css",
    "./styles/*": "./dist/styles/*",
    "./components/button": {
      "types": "./dist/components/button.d.ts",
      "import": "./dist/components/button.js",
      "default": "./dist/components/button.js"
    },
    "./button": {
      "types": "./dist/components/button.d.ts",
      "import": "./dist/components/button.js",
      "default": "./dist/components/button.js"
    },
    "./components/card": {
      "types": "./dist/components/card.d.ts",
      "import": "./dist/components/card.js",
      "default": "./dist/components/card.js"
    },
    "./card": {
      "types": "./dist/components/card.d.ts",
      "import": "./dist/components/card.js",
      "default": "./dist/components/card.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    }
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "tailwindcss": "^4"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": false
    }
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.6.1",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.2.9"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@tailwindcss/cli": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "shadcn",
    "tailwindcss",
    "nextjs"
  ],
  "license": "MIT"
}
